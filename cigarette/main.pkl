amends
  "https://raw.githubusercontent.com/Frnd-me/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "arbitrator.pkl"
import "defs.pkl"
import "smoker.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["arbitrator"] = arbitrator.sm
    ["smoker"] = smoker.sm
  }
}
instantiate {
  ["arbitrator"] = "arbitrator"
  for (s in defs.smokers) { [s] = "smoker" }
}
instanceData {
  for (s in defs.smokers) {
    [s] { ["smokerId"] = "'\(s)'" }
  }
}
