amends
  "https://raw.githubusercontent.com/Frnd-me/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "counter.pkl"
import "producer.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["producerMachine"] = producer.sm
    ["counterMachine"] = counter.sm
  }
}
instantiate {
  ["producer"] = "producerMachine"
  ["counter"] = "counterMachine"
}
instanceSubscriptions {
  ["counter"] { "producer" }
  ["producer"] { "counter" }
}
