amends "https://raw.githubusercontent.com/UIBK-DPS-DC/Cirrina-Specifications/main/pkl/JobDescription.pkl"

import "https://raw.githubusercontent.com/UIBK-DPS-DC/Cirrina-Specifications/main/pkl/HttpServiceImplementationDescription.pkl"
import "https://raw.githubusercontent.com/UIBK-DPS-DC/Cirrina-UseCases/main/railway/csml/railway.pkl" as railwayCSM

local isRemote = read?("env:RAILWAY_REMOTE") != null

collaborativeStateMachine = railwayCSM
stateMachineName = "crossing"
localData = new Mapping {}
bindEventInstanceIds = new Listing {}
runtimeName = "runtime"

serviceImplementations {
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/gate/up"
    method = "POST"
    name = "gateUp"
    cost = 1.0
    `local` = !isRemote
  }
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/gate/down"
    method = "POST"
    name = "gateDown"
    cost = 1.0
    `local` = !isRemote
  }
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/light/on"
    method = "POST"
    name = "lightOn"
    cost = 1.0
    `local` = !isRemote
  }
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/light/off"
    method = "POST"
    name = "lightOff"
    cost = 1.0
    `local` = !isRemote
  }
}