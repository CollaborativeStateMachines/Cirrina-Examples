amends "https://raw.githubusercontent.com/UIBK-DPS-DC/Cirrina-Specifications/main/pkl/JobDescription.pkl"

import "https://raw.githubusercontent.com/UIBK-DPS-DC/Cirrina-Specifications/main/pkl/HttpServiceImplementationDescription.pkl"
import "https://raw.githubusercontent.com/UIBK-DPS-DC/Cirrina-Specifications/main/pkl/CollaborativeStateMachineDescription.pkl" as CSM

local isRemote = read?("env:RAILWAY_REMOTE") != null

// ------------------------ CSM -------------------------------
local railwayCSM: CSM = new {
  name = "Railway"
  version = "2.0"
  stateMachines {
    crossing
  }
  persistentContext {
    variables {
      new {
        name = vPersistentDataVariable
        value = "0"
      }
    }
  }
}

// ------------------------ Service Types -------------------------------
local stGateUp = "gateUp"
local stGateDown = "gateDown"
local stLightOn = "lightOn"
local stLightOff = "lightOff"

// ------------------------ Events -------------------------------
local eSensor = "sensor"
local eGateUp = "gateUp"
local eGateDown = "gateDown"
local eLightOn = "lightOn"
local eLightOff = "lightOff"

// ------------------------ Variables -------------------------------
local vLocalDataVariable = "localDataVariable"
local vPersistentDataVariable = "persistentDataVariable"
local vValue = "$value"

// ------------------------ Raise Actions -------------------------------
local aRaiseGateUp: CSM.RaiseActionDescription = new {
  event {
    name = eGateUp
    channel = "internal"
  }
}

local aRaiseGateDown: CSM.RaiseActionDescription = new {
  event {
    name = eGateDown
    channel = "internal"
  }
}

local aRaiseLightOn: CSM.RaiseActionDescription = new {
  event {
    name = eLightOn
    channel = "internal"
  }
}

local aRaiseLightOff: CSM.RaiseActionDescription = new {
  event {
    name = eLightOff
    channel = "internal"
  }
}

// ------------------------ Invoke Actions -------------------------------
local aDoGateUp: CSM.InvokeActionDescription = new {
  serviceType = stGateUp
  isLocal = !isRemote
}

local aDoGateDown: CSM.InvokeActionDescription = new {
  serviceType = stGateDown
  isLocal = !isRemote
}

local aDoLightOn: CSM.InvokeActionDescription = new {
  serviceType = stLightOn
  isLocal = !isRemote
}

local aDoLightOff: CSM.InvokeActionDescription = new {
  serviceType = stLightOff
  isLocal = !isRemote
}

// ------------------------ Assign Actions -------------------------------
local aWriteData: CSM.AssignActionDescription = new {
  variable {
    name = if (isRemote) vPersistentDataVariable else vLocalDataVariable
    value = "utility:genRandPayload([0, 8, 32, 256, 512, 1024, 4096, 8192])"
  }
}

// ------------------------ Guards -------------------------------
local isValue: CSM.GuardDescription = new {
  expression = vValue
}

local isNotValue: CSM.GuardDescription = new {
  expression = "\(vValue) == false"
}

// ------------------------ Context -------------------------------
local commonLocalContext: CSM.ContextDescription = new {
  variables {
    new {
      name = vLocalDataVariable
      value = "0"
    }
  }
}

// ------------------------ Crossing SM -------------------------------
local crossing: CSM.StateMachineDescription = new {
  name = "crossing"
  localContext = commonLocalContext
  states {
    away
    approach
    close
    present
    leaving
    left
  }
  stateMachines {
    gate
    light
  }
}

local away: CSM.StateDescription = new {
  name = "away"
  initial = true
  on {
    new {
      event = eSensor
      guards {
        isValue
      }
      target = approach.name
    }
    new {
      event = eSensor
      guards {
        isNotValue
      }
      actions {
        aRaiseLightOff
        aRaiseGateUp
      }
    }
  }
}

local approach: CSM.StateDescription = new {
  name = "approach"
  on {
    new {
      event = eSensor
      guards {
        isNotValue
      }
      target = close.name
    }
    new {
      event = eSensor
      guards {
        isValue
      }
      actions {
        aRaiseLightOn
        aRaiseGateDown
      }
    }
  }
}

local close: CSM.StateDescription = new {
  name = "close"
  on {
    new {
      event = eSensor
      guards {
        isValue
      }
      target = present.name
    }
    new {
      event = eSensor
      guards {
        isNotValue
      }
      actions {
        aRaiseLightOn
        aRaiseGateDown
      }
    }
  }
}

local present: CSM.StateDescription = new {
  name = "present"
  on {
    new {
      event = eSensor
      guards {
        isNotValue
      }
      target = leaving.name
    }
    new {
      event = eSensor
      guards {
        isValue
      }
      actions {
        aRaiseLightOn
        aRaiseGateDown
      }
    }
  }
}

local leaving: CSM.StateDescription = new {
  name = "leaving"
  initial = true
  on {
    new {
      event = eSensor
      guards {
        isValue
      }
      target = left.name
    }
    new {
      event = eSensor
      guards {
        isNotValue
      }
      actions {
        aRaiseLightOff
        aRaiseGateUp
      }
    }
  }
}

local left: CSM.StateDescription = new {
  name = "left"
  initial = true
  on {
    new {
      event = eSensor
      guards {
        isNotValue
      }
      target = away.name
    }
    new {
      event = eSensor
      guards {
        isValue
      }
      actions {
        aRaiseLightOff
        aRaiseGateUp
      }
    }
  }
}

// ------------------------ Gate SM -------------------------------
local gate: CSM.StateMachineDescription = new {
  name = "gate"
  localContext = commonLocalContext
  states {
    gateUp
    gateDown
  }
}

local gateUp: CSM.StateDescription = new {
  name = "up"
  initial = true
  on {
    new {
      event = eGateUp
      actions {
        aDoGateUp
        aWriteData
      }
    }
    new {
      event = eGateDown
      target = gateDown.name
    }
  }
}

local gateDown: CSM.StateDescription = new {
  name = "down"
  on {
    new {
      event = eGateUp
      target = gateUp.name
    }
    new {
      event = eGateDown
      actions {
        aDoGateDown
        aWriteData
      }
    }
  }
}

// ------------------------ Light SM -------------------------------
local light: CSM.StateMachineDescription = new {
  name = "light"
  localContext = commonLocalContext
  states {
    lightOff
    lightOn
  }
}

local lightOff: CSM.StateDescription = new {
  name = "off"
  initial = true
  on {
    new {
      event = eLightOff
      actions {
        aDoLightOff
        aWriteData
      }
    }
    new {
      event = eLightOn
      target = lightOn.name
    }
  }
}

local lightOn: CSM.StateDescription = new {
  name = "on"
  on {
    new {
      event = eLightOff
      target = lightOff.name
    }
    new {
      event = eLightOn
      actions {
        aDoLightOn
        aWriteData
      }
    }
  }
}

collaborativeStateMachine = railwayCSM
stateMachineName = "crossing"
localData = new Mapping {}
bindEventInstanceIds = new Listing {}
runtimeName = "runtime"

serviceImplementations {
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/gate/up"
    method = "POST"
    name = "gateUp"
    cost = 1.0
    `local` = !isRemote
  }
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/gate/down"
    method = "POST"
    name = "gateDown"
    cost = 1.0
    `local` = !isRemote
  }
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/light/on"
    method = "POST"
    name = "lightOn"
    cost = 1.0
    `local` = !isRemote
  }
  new HttpServiceImplementationDescription {
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/light/off"
    method = "POST"
    name = "lightOff"
    cost = 1.0
    `local` = !isRemote
  }
}