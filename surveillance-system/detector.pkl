import "csm:Csml"

import "events.pkl"

class DetectorStateMachine extends Csml.StateMachineDescription {
  name = "detector"
  localContext {
    variables {
      new {
        name = "image"
        value = "''"
      }
      new {
        name = "hasDetectedPersons"
        value = "false"
      }
    }
  }
  states {
    new {
      name = "capturing"
      initial = true
      entry {
        new Csml.InvokeActionDescription {
          serviceType = "cameraCapture"
          input {
            new {
              name = "cameraId"
              value = "0"
            }
          }
          output {
            new {
              reference = "image"
            }
          }
          done {
            new {
              name = "captured"
              channel = "internal"
            }
          }
        }
      }
      on {
        new {
          event = "captured"
          target = "processing"
        }
      }
    }
    new {
      name = "processing"
      entry {
        new Csml.InvokeActionDescription {
          serviceType = "detectPersons"
          isLocal = true
          input {
            new {
              name = "image"
              value = "image"
            }
          }
          output {
            new {
              reference = "hasDetectedPersons"
            }
          }
          done {
            new {
              name = "detectedPersons"
              channel = "internal"
            }
          }
        }
      }
      on {
        new {
          event = "detectedPersons"
          guards {
            new Csml.GuardDescription {
              expression = "hasDetectedPersons == true"
            }
          }
          actions {
            new Csml.RaiseActionDescription {
              event {
                name = events.foundPersons
                channel = "global"
                data {
                  new {
                    name = "image"
                    value = "image"
                  }
                }
              }
            }
          }
        }
        new {
          event = "timeout"
          target = "capturing"
        }
        new {
          event = "alarm"
          target = "alarm"
        }
      }
      after {
        new Csml.TimeoutActionDescription {
          name = "captureTimeout"
          delay = "500" // Note: in the future use Duration type e.g. 500.ms
          action = new Csml.RaiseActionDescription {
            event {
              name = "timeout"
              channel = "internal"
            }
          }
        }
      }
    }
    new {
      name = "alarm"
      entry {
        new Csml.InvokeActionDescription {
          serviceType = "alarmOn"
        }
      }
      exit {
        new Csml.InvokeActionDescription {
          serviceType = "alarmOff"
        }
      }
      on {
        new {
          event = "disarm"
          target = "capturing"
        }
      }
    }
  }
}