amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/ServiceImplementationBindings.pkl"

bindings {
  new HttpServiceImplementationBinding {
    name = "cameraCapture"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8001
    endPoint = "/capture"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "detectPersons"
    `local` = true
    scheme = "http"
    host = "localhost"
    port = 8002
    endPoint = "/detect"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "alarmOn"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8001
    endPoint = "/alarm/on"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "alarmOff"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8001
    endPoint = "/alarm/off"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "analyze"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8003
    endPoint = "/analyze"
    method = "POST"
  }
}