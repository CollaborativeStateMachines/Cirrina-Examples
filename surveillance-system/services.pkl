amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/ServiceImplementationBindings.pkl"

bindings {
  new HttpServiceImplementationBinding {
    name = "cameraCapture"
    `local` = true
    scheme = "http"
    host = "services"
    port = 8000
    endPoint = "/bell/on"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "detectPersons"
    `local` = false
    scheme = "http"
    host = "services"
    port = 8000
    endPoint = "/bell/off"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "alarmOn"
    `local` = false
    scheme = "http"
    host = "services"
    port = 8000
    endPoint = "/gate/up"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "alarmOff"
    `local` = false
    scheme = "http"
    host = "services"
    port = 8000
    endPoint = "/gate/down"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "analyze"
    `local` = false
    scheme = "http"
    host = "services"
    port = 8000
    endPoint = "/light/on"
    method = "POST"
  }
}