import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  transient {
    ["tryCounter"] = "0"
    ["eatCounter"] = "0"
  }
  states {
    ["requestingFork"] = new csml.Initial {
      entry {
        new csml.Eval { expression = "++tryCounter" }
        new csml.Raise {
          event = new csml.Global {
            topic = "requesting"
            data {
              ["replyTo"] = "philosopherId"
              ["forkId"] = "forkId"
            }
          }
        }
      }
      on {
        ["allocated"] = new csml.Transition { to = "eating" }
        ["denied"] = new csml.Transition { to = "evaluateCounter" }
      }
    }
    ["evaluateCounter"] = new csml.State {
      always {
        new csml.Transition {
          to = "requestingFork"
          iif = "eatCounter < 16000"
          or = "leave"
        }
      }
    }
    ["eating"] = new csml.State {
      always {
        new csml.Transition {
          to = "evaluateCounter"
          do {
            new csml.Eval { expression = "++eatCounter" }
            new csml.Raise {
              event = new csml.Global {
                topic = "finished"
                data { ["forkId"] = "forkId" }
              }
            }
          }
        }
      }
    }
    ["leave"] = new csml.Terminal {
      entry { new csml.Raise { event = new csml.Global { topic = "done" } } }
    }
  }
}
