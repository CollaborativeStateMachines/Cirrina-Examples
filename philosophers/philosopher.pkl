import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  transient {
    ["tryCounter"] = "0"
    ["eatCounter"] = "0"
    ["philosopherId"] = "std:getSequentialIdInt()"
  }
  states {
    ["requestingFork"] = new csml.Initial {
      entry {
        new csml.Eval { expression = "tryCounter = tryCounter + 1" }
        new csml.Raise {
          event = new csml.Global {
            topic = "requesting"
            data {
              ["forkOne"] = "philosopherId"
            }
          }
        }
      }
      on {
        ["allocated"] = new csml.Transition {
          to = "eating"
          iif = "$forkOne == philosopherId && ($forkOne + 1) % 6 == (philosopherId + 1) % 6"
        }
        ["denied"] = new csml.Transition {
          to = "evaluateCounter"
          iif = "$forkOne == philosopherId && ($forkOne + 1) % 6 == (philosopherId + 1) % 6"
        }
      }
    }
    ["evaluateCounter"] = new csml.State {
      always {
        new csml.Transition {
          to = "requestingFork"
          iif = "eatCounter <= 16000"
          or = "leave"
        }
      }
    }
    ["eating"] = new csml.State {
      entry {
        new csml.Eval { expression = "eatCounter = eatCounter + 1" }
        new csml.Raise {
          event = new csml.Global {
            topic = "finished"
            data {
              ["forkOne"] = "philosopherId"
            }
          }
        }
      }
      on {
        ["finished"] = new csml.Transition {
          to = "evaluateCounter"
          iif = "$forkOne == philosopherId && ($forkOne + 1) % 6 == (philosopherId + 1) % 6"
        }
      }
    }
    ["leave"] = new csml.Terminal {
      entry {
        new csml.Raise { event = new csml.Global { topic = "done" } }
      }
    }
  }
}
