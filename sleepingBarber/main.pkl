amends
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "barber.pkl"
import "customer.pkl"
import "defs.pkl"
import "waitingRoom.pkl"

version = "4.0.0"
stateMachines {
  ["barber"] = barber.sm
  for (c in defs.customers) {
    [c.toString()] = customer.createCustomer(c)
  }
  ["waitingRoom"] = waitingRoom.sm
}
