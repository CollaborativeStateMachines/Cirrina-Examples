import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  states {
    ["sleeping"] = new csml.Initial {
      entry {
        new csml.Raise { event = new csml.Global { topic = "statusSleeping" } }
      }
      on {
        ["ready"] = new csml.Transition {
          do {}
        }
        ["enter"] = new csml.Transition {
          to = "cutting"
        }
        ["stopCutting"] = new csml.Transition {
          to = "stop"
        }
      }
    }
    ["cutting"] = new csml.State {
      always {
        new csml.Transition {
          to = "sleeping"
          iif = "std:busyWait(1000)"
          do {
            new csml.Raise {
              event = new csml.Global {
                topic = "done"
                data {
                  ["customer"] = "$customer"
                }
              }
            }
            new csml.Raise {
              event = new csml.Global { topic = "getNext" }
            }
          }
        }
      }
    }
    ["stop"] = new csml.Terminal {}
  }
}
