import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  states {
    ["sleeping"] = new csml.Initial {
      entry { new csml.Raise { event = new csml.Global { topic = "statusSleeping" } } }
      on {
        ["enter"] = new csml.Transition {
          to = "cutting"
          do {
            new csml.Raise { event = new csml.Global { topic = "comeIn" }; target = "$customer" }
          }
        }
        ["terminate"] = new csml.Transition { to = "done" }
      }
    }
    ["cutting"] = new csml.State {
      always {
        new csml.Transition {
          to = "sleeping"
          iif = "(function (){ let x = 0; while ( x < 1000) {x++}; return true})()"
          do {
            new csml.Raise { event = new csml.Global { topic = "done" }; target = "$customer" }
            new csml.Raise { event = new csml.Global { topic = "getNext" } }
          }
        }
      }
    }
    ["done"] = new csml.Terminal {}
  }
}
