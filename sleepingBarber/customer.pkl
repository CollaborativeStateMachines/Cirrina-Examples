import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

function createCustomer(id: Int) = new csml.StateMachine {
  transient {
    ["counter"] = "0"
    ["customerId"] = "\(id)"
  }
  states {
    ["init"] = new csml.Initial {
      on {
        ["ready"] = new csml.Transition {
          to = "requestHaircut"
        }
      }
    }
    ["requestHaircut"] = new csml.State {
      entry {
        new csml.Raise {
          event = new csml.Global {
            topic = "customerEnter"
            data {
              ["customer"] = "customerId"
            }
          }
        }
      }
      on {
        ["full"] = new csml.Transition {
          to = "requestHaircut"
          iif = "$customer == customerId"
        }
        ["enter"] = new csml.Transition {
          to = "gettingHaircut"
          iif = "$customer == customerId"
        }
        ["waiting"] = new csml.Transition {
          to = "waiting"
          iif = "$customer == customerId"
        }
      }
    }
    ["gettingHaircut"] = new csml.State {
      entry {
        new csml.Eval { expression = "counter = counter + 1" }
      }
      on {
        ["done"] = new csml.Transition {
          to = "evaluateCounter"
          iif = "$customer == customerId"
        }
      }
    }
    ["evaluateCounter"] = new csml.State {
      always {
        new csml.Transition {
          to = "requestHaircut"
          iif = "counter < 1000"
          or = "leave"
        }
      }
    }
    ["waiting"] = new csml.State {
      on {
        ["enter"] = new csml.Transition {
          to = "gettingHaircut"
          iif = "$customer == customerId"
        }
      }
    }
    ["leave"] = new csml.Terminal {
      entry {
        new csml.Raise { event = new csml.Global { topic = "doneCutting" } }
      }
    }
  }
}
