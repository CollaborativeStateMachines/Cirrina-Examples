import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  transient {
    ["target"] = "''"
    ["sender"] = "''"
    ["count"] = "0"
  }
  states {
    ["run"] = new csml.Initial {
      entry {
        new csml.Raise { event = new csml.Global { topic = "done" } }
        new csml.Eval { expression = "++count" }
        new csml.Eval { expression = "target = std:takeRandom(otherBigs)" }
        new csml.Raise {
          event = new csml.Global {
            topic = "ping"
            data { ["sender"] = "bigId" }
          }
          target = "target"
        }
      }
      on {
        ["ping"] = new csml.Transition {
          iif = "$sender != bigId"
          do {
            new csml.Eval { expression = "sender = $sender"}
            new csml.Raise {
              event = new csml.Global {
                topic = "pong"
                data { ["sender"] = "bigId" }
              }
              target = "sender"
            }
          }
        }
        ["pong"] = new csml.Transition {
          iif = "$sender == target"
          do {
            new csml.Match {
              value = "count < 20000"
              cases {
                new csml.Case {
                  of = "false"; then {
                    new csml.Raise { event = new csml.Global { topic = "done" } }
                  }
                }
                new csml.Case {
                  of = "true"; then {
                    new csml.Eval { expression = "++count" }
                    new csml.Eval { expression = "target = std:takeRandom(otherBigs)" }
                    new csml.Raise {
                      event = new csml.Global {
                        topic = "ping"
                        data { ["sender"] = "bigId" }
                      }
                      target = "target"
                    }
                  }
                }
              }
            }
          }
        }
        ["shutdown"] = new csml.Transition {
          to = "done"
        }
      }
    }
    ["done"] = new csml.Terminal {}
  }
}
