amends
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "big.pkl"
import "defs.pkl"
import "sink.pkl"

version = "4.0.0"
stateMachines {
  ["sink"] = sink.sm
  for (b in defs.bigs) {
    [b.toString()] = big.createBig(b)
  }
}
