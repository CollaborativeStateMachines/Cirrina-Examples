amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

local n = 12

collaborativeStateMachine {
  stateMachines {
    ["big"] {
      transient { ["count"] = "0" }
      states {
        ["run"] = new Initial {
          entry {
            new Eval { expression = "++count" }
            new Emit {
              event {
                topic = "ping"
                data { ["sender"] = "id" }
              }
              target = "std:takeRandom(peers)"
            }
          }
          on {
            ["ping"] {
              yields {
                new Emit {
                  event {
                    topic = "pong"
                    data { ["sender"] = "id" }
                  }
                  target = "$sender"
                }
              }
            }
            ["pong"] {
              yields {
                new Match {
                  cases {
                    new Case {
                      of = "count == 20000"
                      yields {
                        new Eval { expression = "++count" }
                        new Emit { event { topic = "done" } }
                      }
                    }
                    new Case {
                      of = "count < 20000"
                      yields {
                        new Emit {
                          event {
                            topic = "ping"
                            data { ["sender"] = "id" }
                          }
                          target = "std:takeRandom(peers)"
                        }
                      }
                    }
                  }
                }
              }
            }
            ["shutdown"] { to = "done" }
          }
        }
        ["done"] = new Terminal {}
      }
    }
    ["sink"] = new StateMachine {
      transient { ["count"] = "0" }
      states {
        ["wait"] = new Initial {
          on {
            ["done"] {
              to = "wait"
              yields { new Eval { expression = "++count" } }
            }
          }
          always {
            new Transition {
              to = "done"
              provided = "count == 12"
            }
          }
        }
        ["done"] = new Terminal { entry { new Emit { event { topic = "shutdown" } } } }
      }
    }
  }
}
instances {
  ["sink"] { stateMachineName = "sink" }
  for (i in IntSeq(0, n - 1)) {
    ["big\(i)"] {
      stateMachineName = "big"
      data {
        ["id"] = "'big\(i)'"
        ["peers"] = "['big0', 'big1', 'big2', 'big3', 'big4', 'big5', 'big6', 'big7', 'big8', 'big9', 'big10', 'big11'] - ['big\(i)']"
      }
    }
  }
}
