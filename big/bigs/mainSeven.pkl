amends
  "https://raw.githubusercontent.com/Frnd-me/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

import "../big.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["big"] = big.sm
  }
}
instances {
  ["seven"] = "big"
}
instanceData {
  ["seven"] {
    ["bigId"] = "'seven'"
    ["otherBigs"] = "['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'eight', 'nine', 'ten', 'eleven', ...]"
  }
}
