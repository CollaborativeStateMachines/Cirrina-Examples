import
  "https://raw.githubusercontent.com/Frnd-me/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  transient { ["numPings"] = "50000" }
  states {
    ["ping"] = new csml.Initial {
      entry {
        new csml.Raise { event = new csml.Global { topic = "ping" } }
        new csml.Eval { expression = "--numPings" }
      }
      on {
        ["pong"] = new csml.Transition {
          iif = "numPings != 0"
          to = "ping"
          or = "done"
        }
      }
    }
    ["done"] = new csml.Terminal {
      entry { new csml.Raise { event = new csml.Global { topic = "done" } } }
    }
  }
}
