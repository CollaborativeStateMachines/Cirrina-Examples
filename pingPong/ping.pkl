amends
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

version = "4.0.0"
collaborativeStateMachine {
  stateMachines {
    ["ping"] = new StateMachine {
      transient { ["numPings"] = "50000" }
      states {
        ["ping"] = new Initial {
          entry {
            new Raise { event = new Global { topic = "ping" } }
            new Eval { expression = "--numPings" }
          }
          on {
            ["pong"] = new Transition { iif = "numPings != 0"; to = "ping"; or = "done" }
          }
        }
        ["done"] = new Terminal {
          entry { new Raise { event = new Global { topic = "done" } } }
        }
      }
    }
  }
}
instances { ["ping"] = "ping" }