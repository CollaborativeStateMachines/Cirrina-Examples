amends "https://raw.githubusercontent.com/Frnd-me/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

local n = 6

collaborativeStateMachine {
  stateMachines {
    ["arbitrator"] {
      transient {
        ["forks"] = "std:repeat(false, \(n))"
        ["waiting"] = "std:repeat(false, \(n))"
      }
      states {
        ["serving"] = new Initial {
          static { ["count"] = "0" }
          on {
            ["hungry"] {
              yields {
                new Match {
                  cases {
                    new Case {
                      of = "!(forks[$id] || forks[($id + 1) % 6])"
                      yields {
                        new Eval { expression = "forks[$id] = forks[($id + 1) % 6] = true" }
                        new Emit { event { topic = "acquire" }; target = "$id" }
                      }
                    }
                  }
                  default = new Eval { expression = "waiting[$id] = true" }
                }
              }
            }
            ["release"] {
              yields {
                new Eval { expression = "forks[$id] = forks[($id + 1) % 6] = false" }
                new Emit { event = new Internal { topic = "test"; data { ["nid"] = "($id + 5) % 6" } } }
                new Emit { event = new Internal { topic = "test"; data { ["nid"] = "($id + 1) % 6" } } }
              }
            }
            ["test"] {
              yields {
                new Match {
                  cases {
                    new Case {
                      of = "waiting[$nid] && !(forks[$nid] || forks[($nid + 1) % 6])"
                      yields {
                        new Eval { expression = "waiting[$nid] = false; forks[$nid] = forks[($nid + 1) % 6] = true" }
                        new Emit { event { topic = "acquire" }; target = "$nid" }
                      }
                    }
                  }
                }
              }
            }
            ["done"] {
              to = "serving"; provided = "count < \(n - 1)"
              yields { new Eval { expression = "++count" } }
              or = "done"
            }
          }
        }
        ["done"] = new Terminal {}
      }
    }
    ["philosopher"] {
      states {
        ["hungry"] = new Initial {
          entry {
            new Emit { event { topic = "hungry"; data { ["id"] = "id" } } }
          }
          on {
            ["acquire"] { to = "eating" }
          }
        }
        ["eating"] {
          static { ["meals"] = "0" }
          exit {
            new Emit { event { topic = "release"; data { ["id"] = "id" } } }
          }
          after {
            ["meals"] = new Timeout {
              delay = "0"
              triggers = new Emit { event = new Internal { topic = "think" } }
            }
          }
          on {
            ["think"] {
              to = "hungry"; provided = "meals < 16000"
              yields { new Eval { expression = "++meals" } }
              or = "sated"
            }
          }
        }
        ["sated"] = new Terminal {
          entry { new Emit { event { topic = "done" } } }
        }
      }
    }
  }
}
instances {
  ["arbitrator"] { stateMachineName = "arbitrator" }
  for (i in IntSeq(0, n - 1)) {
    ["\(i)"] { 
      stateMachineName = "philosopher"
      data { ["id"] = "\(i)" } 
    }
  }
}