amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

local n = 6

collaborativeStateMachine {
  stateMachines {
    ["arbitrator"] {
      transient {
        ["forks"] = "std:repeat(false, \(n))"
        ["waiting"] = "std:repeat(false, \(n))"
        ["count"] = "0"
      }
      states {
        ["serving"] = new Initial {
          on {
            ["hungry"] {
              yields {
                new Match {
                  cases {
                    new Case {
                      of = "!(forks[$fid] || forks[($fid + 1) % 6])"
                      yields {
                        new Assign { expression = "forks[$fid] = forks[($fid + 1) % 6] = true" }
                        new Emit { event { topic = "acquire" }; target = "$recipient" }
                      }
                    }
                  }
                  default = new Assign { expression = "waiting[$fid] = true" }
                }
              }
            }
            ["release"] {
              yields {
                new Assign { expression = "forks[$fid] = forks[($fid + 1) % 6] = false" }
                new Emit { event = new Internal { topic = "test"; data { ["nid"] = "($fid + 5) % 6" } } }
                new Emit { event = new Internal { topic = "test"; data { ["nid"] = "($fid + 1) % 6" } } }
              }
            }
            ["test"] {
              yields {
                new Match {
                  cases {
                    new Case {
                      of = "waiting[$nid] && !(forks[$nid] || forks[($nid + 1) % 6])"
                      yields {
                        new Assign { expression = "waiting[$nid] = false; forks[$nid] = forks[($nid + 1) % 6] = true" }
                        new Emit { event { topic = "acquire" }; target = "'philosopher' + $nid" }
                      }
                    }
                  }
                }
              }
            }
            ["done"] {
              to = "serving"; provided = "count < 5"
              yields { new Assign { expression = "++count" } }
              or = "done"
            }
          }
        }
        ["done"] = new Terminal {}
      }
    }
    ["philosopher"] {
      transient {
        ["meals"] = "0"
      }
      states {
        ["wait"] = new Initial {
          on {
            ["start"] = new Transition { to = "hungry" }
          }
        }
        ["hungry"] = new State {
          entry {
            new Emit { event { topic = "hungry"; data { ["recipient"] = "id"; ["fid"] = "fid" } } }
          }
          on {
            ["acquire"] { to = "eating" }
          }
        }
        ["eating"] {
          exit {
            new Emit { event { topic = "release"; data { ["fid"] = "fid" } } }
          }
          after {
            ["meals"] = new Timeout {
              delay = "0"
              triggers = new Emit { event = new Internal { topic = "think" } }
            }
          }
          on {
            ["think"] {
              to = "hungry"; provided = "meals < 16000"
              yields { new Assign { expression = "++meals" } }
              or = "sated"
            }
          }
        }
        ["sated"] = new Terminal {
          entry { new Emit { event { topic = "done" } } }
        }
      }
    }
  }
}
instances {
  ["arbitrator"] { stateMachineName = "arbitrator" }
  for (i in IntSeq(0, n - 1)) {
    ["philosopher\(i)"] { 
      stateMachineName = "philosopher"
      data { ["id"] = "'philosopher\(i)'"; ["fid"] = "\(i)" } 
    }
  }
}