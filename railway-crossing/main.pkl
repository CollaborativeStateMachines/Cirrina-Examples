import "@csm/Csml.pkl"

import "crossing/crossing.pkl"

class CrossingCollaborativeStateMachine extends Csml.CollaborativeStateMachine {
  name    = "crossing"
  version = "3.0"
  stateMachines {
    new crossing.CrossingStateMachine {}
  }
}

function main(): Csml.CollaborativeStateMachine = new CrossingCollaborativeStateMachine {}