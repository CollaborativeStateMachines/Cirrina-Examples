import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"

import "events.pkl"

// Action that raises the gate up event.
const raiseGateUpAction = new Csml.RaiseActionDescription {
  event {
    name = events.gateUp
    data {
      new {
        name = "traceId"
        value = "$traceId"
      }
      new {
        name = "spanId"
        value = "$spanId"
      }
    }
    channel = "global"
  }
}

// Action that raises the gate down event, includes the train speed as event data.
const raiseGateDownAction = new Csml.RaiseActionDescription {
  event {
    name    = events.gateDown
    data {
      new {
        name = "approachingSpeed"
        value = "approachingSpeed"
      }
    }
    channel = "global"
  }
}

// Action that raises the light on event, includes the train speed as event data.
const raiseLightOnAction = new Csml.RaiseActionDescription {
  event {
    name    = events.lightOn
    data {
      new {
        name = "approachingSpeed"
        value = "approachingSpeed"
      }
    }
    channel = "global"
  }
}

// Action that raises the light off event.
const raiseLightOffAction = new Csml.RaiseActionDescription {
  event {
    name    = events.lightOff
    channel = "global"
  }
}

// Action that raises the light earlz warning event.
const raiseLightEarlyWarningAction  = new Csml.RaiseActionDescription {
  event {
    name = events.lightEarlyWarning
    channel = "global"
  }
}

// Action that increments the number of trains passed.
const incrementNumTrainsPassed = new Csml.AssignActionDescription {
  variable = new {
    name = "numTrainsPassed"
    value = "numTrainsPassed + 1"
  }
}

// Guard that passes when the event data (its value $value) is true.
const isEventDataTrueGuard = new Csml.GuardDescription {
  expression = "$value == true"
}

// Guard that passes when the event data (its value $value) is false.
const isEventDataFalseGuard = new Csml.GuardDescription {
  expression = "$value == false"
}

// Map defining all local context variables for ControllerStateMachine.
const localVariables = Map("numTrainsPassed", "0", "approachingSpeed", "0", "gateDownTime", "0")

class ControllerStateMachine extends Csml.StateMachineDescription {
  name = "controller"
  local self = this
  persistentContext {
    variables {
      new {
        name = self.name + "_State"
        value = "{:}"
      }
    }
  }
  localContext {
    variables {
      for (_var, _val in localVariables) {
        new {
          name = _var
          value = _val
        }
      }
    }
  }
  states {
    new {
      name    = "init"
      initial = true
      entry {
        raiseLightOffAction
        new Csml.RaiseActionDescription {
          event {
            name = events.gateUp
            data {
              new {
                name = "traceId"
                value = "''"
              }
              new {
                name = "spanId"
                value = "''"
              }
            }
            channel = "global"
          }
        }
      }
      always {
        new {
          target = "away"
        }
      }
    }
    new {
      name = "away"
      localContext {
        variables {
          new {
            name = "lastUpdate_Timestamp"
            value = "utility:now()"
          }
        }
      }
      on {
        new {
          event  = events.sensor
          target = "approach"
          guards { isEventDataTrueGuard }
        }
        new {
          event = events.trainOnTheWay
          actions {
            new Csml.AssignActionDescription {
              variable = new {
                name = "approachingSpeed"
                value = "$approachingSpeed"
              }
            }
          }
          target = "earlyWarning"
        }
      }
    }
    new {
      name = "earlyWarning"
      localContext {
        variables {
          new {
            name = "lastUpdate_Timestamp"
            value = "utility:now()"
          }
        }
      }
      entry {
        raiseLightEarlyWarningAction
        new Csml.AssignActionDescription {
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"earlyWarning\", lastUpdate_Timestamp)"
          }
        }
      }
      on {
        new {
          event  = events.sensor
          target = "approach"
          guards { isEventDataTrueGuard }
        }
      }
    }
    new {
      name = "approach"
      localContext {
        variables {
          new {
            name = "lastUpdate_Timestamp"
            value = "utility:now()"
          }
        }
      }
      entry {
        new Csml.AssignActionDescription {
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"approach\", lastUpdate_Timestamp)"
          }
        }
      }
      on {
        new {
          event  = events.sensor
          target = "close"
          guards { isEventDataFalseGuard }
        }
      }
    }
    new {
      name = "close"
      localContext {
        variables {
          new {
            name = "signalDelay"
            value = "0"
          }
          new {
            name = "lastUpdate_Timestamp"
            value = "utility:now()"
          }
        }
      }
      entry {
        new Csml.AssignActionDescription {
          variable = new {
            name = "approachingSpeed"
            value = "$trainSpeed"
          }
        }
        raiseGateDownAction
        raiseLightOnAction
        new Csml.AssignActionDescription {
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"close\", lastUpdate_Timestamp)"
          }
        }
        new Csml.AssignActionDescription{
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"trainSpeed\", approachingSpeed)"
          }
        }
      }
      on {
        new {
          event = "gateIsDown"
          actions {
            new Csml.AssignActionDescription {
              variable = new {
                name = "signalDelay"
                value = "$downDelay"
              }
            }
            new Csml.AssignActionDescription {
              variable = new {
                name = "gateDownTime"
                value = "lastUpdate_Timestamp + signalDelay"
              }
            }
            new Csml.AssignActionDescription {
              variable = new {
                name = self.name + "_State"
                value = "utility:appendToMap(\(self.name + "_State"), \"signalDelay\", signalDelay)"
              }
            }
          }
        }
        new {
          event  = events.sensor
          target = "present"
          guards { isEventDataTrueGuard }
        }
      }
    }
    new {
      name = "present"
      localContext {
        variables {
          new {
            name = "lastUpdate_Timestamp"
            value = "utility:now()"
          }
        }
      }
      entry {
        incrementNumTrainsPassed
        new Csml.AssignActionDescription {
          variable = new {
            name = self.name + "_State"
            value = "utility:replaceInMap(\(self.name + "_State"), \"numsTrainsPassed\", numTrainsPassed)"
          }
        }
        new Csml.AssignActionDescription {
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"present\", lastUpdate_Timestamp)"
          }
        }
      }
      on {
        new {
          event  = events.sensor
          target = "leaving"
          guards { isEventDataFalseGuard }
        }
      }
    }
    new {
      name = "leaving"
      localContext {
        variables {
          new {
            name = "lastUpdate_Timestamp"
            value = "utility:now()"
          }
        }
      }
      entry {
        raiseGateUpAction
        new Csml.RaiseActionDescription {
          event {
            name = events.trainOnTheWay
            data {
              new {
                name = "approachingSpeed"
                value = "approachingSpeed"
              }
            }
            channel = "global"
          }
        }
        new Csml.AssignActionDescription {
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"leaving\", lastUpdate_Timestamp)"
          }
        }
        new Csml.AssignActionDescription{
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"downTime\", (lastUpdate_Timestamp - gateDownTime))"
          }
        }
      }
      on {
        new {
          event  = events.sensor
          target = "left"
          guards { isEventDataTrueGuard }
        }
      }
    }
    new {
      name = "left"
      localContext {
        variables {
          new {
            name = "lastUpdate_Timestamp"
            value = "utility:now()"
          }
        }
      }
      entry {
        raiseLightOffAction
        new Csml.AssignActionDescription {
          variable = new {
            name = self.name + "_State"
            value = "utility:appendToMap(\(self.name + "_State"), \"left\", lastUpdate_Timestamp)"
          }
        }
      }
      on {
        new {
          event  = events.sensor
          target = "away"
          guards { isEventDataFalseGuard }
        }
      }
    }
  }
}