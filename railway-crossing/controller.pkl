import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"

import "events.pkl"

// Map defining all local context variables for ControllerStateMachine.
const localVariables = Map("numTrainsPassed", "0", "approachingSpeed", "0", "gateDownTime", "0")

const function createRaiseActionGlobal(e: String): Csml.RaiseActionDescription =
    new Csml.RaiseActionDescription {
      event {
        name = e
        channel = "global"
      }
}

const function createRaiseActionGlobalWithData(e: String, _data: Map<String,String>): Csml.RaiseActionDescription =
    new Csml.RaiseActionDescription {
      event {
        name = e
        data {
          for (_name, _value in _data) {
            new {
              name = _name
              value = _value
            }
          }
        }
        channel = "global"
      }
    }

const function context(v: Map<String, String>): Listing<Csml.ContextVariableDescription> = new Listing {
    for (_n, _v in v) {
      new Csml.ContextVariableDescription {
        name = _n
        value = _v
      }
    }
  }

const function to(targetState: String): Listing<Csml.TransitionDescription> = new Listing {
  new Csml.TransitionDescription {
    target = targetState
  }
}

const function createOnTransition(e: String, t: String, a: Listing, guardExpression: String): Csml.OnTransitionDescription =
  new Csml.OnTransitionDescription {
    event = e
    target = t
    actions = a
    guards { new Csml.GuardDescription { expression = guardExpression } }
}

const function createInternalOnTransition(e: String, a: Listing, guardExpression: String): Csml.OnTransitionDescription =
  new Csml.OnTransitionDescription {
    event = e
    actions = a
    guards { new Csml.GuardDescription { expression = guardExpression } }
}

const function createAssignAction(_n: String, _v: String): Csml.AssignActionDescription =
      new Csml.AssignActionDescription {
        variable = new {
          name = _n
          value = _v
        }
  }

const function createAppendToCrossingState(s: String, k: String, v: String): Csml.AssignActionDescription =
    new Csml.AssignActionDescription {
      variable = new {
        name = s + "_State"
        value = "utility:appendToMap(\(s + "_State"),\"\(k)\", \(v))"
      }
}

const function createReplaceInCrossingState(s: String, k: String, v: String): Csml.AssignActionDescription =
    new Csml.AssignActionDescription {
      variable = new {
        name = s + "_State"
        value = "utility:replaceInMap(\(s + "_State"), \"\(k)\", \(v))"
      }
}

class ControllerStateMachine extends Csml.StateMachineDescription {
  name = "controller"
  local self = this
  persistentContext {
    variables = context(Map(self.name + "_State", "{:}"))
  }
  localContext {
    variables = context(localVariables)
  }
  states {
    new {
      name    = "init"
      initial = true
      entry {
        createRaiseActionGlobal(events.lightOff)
        createRaiseActionGlobalWithData(events.gateUp, Map("traceId", "''", "spanId", "''"))
      }
      always = to("away")
    }
    new {
      name = "away"
      localContext {
        variables = context(Map("lastUpdate_Timestamp", "utility:now()"))
      }
      on {
        createOnTransition(events.sensor, "approach", new Listing {}, "$value")
        createInternalOnTransition(events.trainOnTheWay, new Listing { createRaiseActionGlobalWithData(events.lightOn, Map ("approachingSpeed", "approachingSpeed")) }, "true")
      }
    }
    new {
      name = "approach"
      localContext {
        variables = context(Map("lastUpdate_Timestamp", "utility:now()"))
      }
      entry {
        createAppendToCrossingState(self.name, "approach", "lastUpdate_Timestamp")
      }
      on {
        createOnTransition(events.sensor, "close", new Listing {}, "!($value)")
      }
    }
    new {
      name = "close"
      localContext {
        variables = context(Map("lastUpdate_Timestamp", "utility:now()", "signalDelay", "0"))
      }
      entry {
        createAssignAction("approachingSpeed", "$trainSpeed")
        createRaiseActionGlobalWithData(events.gateDown, Map("traceId", "''", "spanId", "''", "approachingSpeed", "approachingSpeed"))
        createRaiseActionGlobalWithData(events.lightOn, Map ("approachingSpeed", "approachingSpeed"))
        createAppendToCrossingState(self.name, "close", "lastUpdate_Timestamp")
        createAppendToCrossingState(self.name, "trainSpeed", "approachingSpeed")
      }
      on {
        createInternalOnTransition("gateIsDown", new Listing { createAssignAction("signalDelay", "$downDelay"); createAssignAction("gateDownTime", "lastUpdate_Timestamp + signalDelay"); createAppendToCrossingState(self.name, "signalDelay", "signalDelay")}, "true");
        createOnTransition(events.sensor, "present", new Listing {}, "$value")
      }
    }
    new {
      name = "present"
      localContext {
        variables = context(Map("lastUpdate_Timestamp", "utility:now()"))
      }
      entry {
        createAssignAction("numTrainsPassed", "numTrainsPassed + 1")
        createAppendToCrossingState(self.name, "present", "lastUpdate_Timestamp")
        createReplaceInCrossingState(self.name, "numTrainsPassed", "numTrainsPassed")
      }
      on {
        createOnTransition(events.sensor, "leaving", new Listing {}, "!($value)")
      }
    }
    new {
      name = "leaving"
      localContext {
        variables = context(Map("lastUpdate_Timestamp", "utility:now()"))
      }
      entry {
        createRaiseActionGlobalWithData(events.gateUp, Map("traceId", "$traceId", "spanId", "$spanId"))
        createRaiseActionGlobalWithData(events.trainOnTheWay, Map("approachingSpeed", "approachingSpeed"))
        createAppendToCrossingState(self.name, "leaving", "lastUpdate_Timestamp")
        createAppendToCrossingState(self.name, "downTime", "(lastUpdate_Timestamp - gateDownTime)")
        }
      on {
        createOnTransition(events.sensor, "left", new Listing {}, "$value")
      }
    }
    new {
      name = "left"
      localContext {
        variables = context(Map("lastUpdate_Timestamp", "utility:now()"))
      }
      entry {
        createRaiseActionGlobal(events.lightOff)
        createAppendToCrossingState(self.name, "left", "lastUpdate_Timestamp")
      }
      on {
        createOnTransition(events.sensor, "away", new Listing {}, "!($value)")
      }
    }
  }
}