module crossing

import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/CollaborativeStateMachineDescription.pkl" as CSML

import "actions.pkl" as Actions
import "events.pkl"  as Events
import "gate.pkl"    as Gate
import "guards.pkl"  as Guards
import "light.pkl"   as Light

stateMachine = new CSML.StateMachineDescription {
  name = "crossing"
  localContext {
    variables {
      new {
          name  = "numTrainsPassedCrossing"
          value = "0"
      }
    }
  }
  states {
    new {
      name    = "away"
      initial = true
      on {
        // On sensor event, transition to the approach state, but only if the value provided within the 
        // event data evaluates to true (the sensor value has changed).
        new {
          event  = Events.sensor
          target = "approach"
          guards { 
            Guards.isEventDataTrue 
          }
        }
        // On sensor event, ensure the lights are off and the gates are up if the value provided within the
        // event data evaluates to false. 
        new {
          event = Events.sensor
          actions {
              Actions.raiseLightOff
              Actions.raiseGateUp
          }
          guards {
            Guards.isEventDataFalse
          }
        }
      }
    }
    new {
      name = "approach"
      on {
        // On sensor event, transition to the close state, but only if the value provided within the event 
        // data evaluates to false (the sensor value has changed).
        new {
          event  = Events.sensor
          target = "close"
          guards {
            Guards.isEventDataFalse
          }
        }
        // On sensor event, ensure the lights are on and the gates are down if the value provided within the
        // event data evaluates to true. 
        new {
          event = Events.sensor
          actions {
            Actions.raiseLightOn
            Actions.raiseGateDown
          }
          guards {
            Guards.isEventDataTrue 
          }
        }
      }
    }
    new {
      name = "close"
      on {
        // ^
        new {
          event  = Events.sensor
          target = "present"
          guards {
            Guards.isEventDataTrue 
          }
        }
        // ^
        new {
          event = Events.sensor
          actions {
            Actions.raiseLightOn
            Actions.raiseGateDown
          }
          guards {
            Guards.isEventDataFalse
          }
        }
      }
    }
    new {
      name = "present"
      on {
        // ^
        new {
          event  = Events.sensor
          target = "leaving"
          guards {
            Guards.isEventDataFalse
          }
        }
        // ^
        new {
          event = Events.sensor
          actions {
            Actions.raiseLightOn
            Actions.raiseGateDown
          }
          guards {
            Guards.isEventDataTrue 
          }
        }
      }
    }
    new {
      name = "leaving"
      initial = true
      on {
        // ^
        new {
          event  = Events.sensor
          target = "left"
          guards {
            Guards.isEventDataTrue 
          }
        }
        // ^
        new {
          event = Events.sensor
          actions {
            Actions.raiseLightOff
            Actions.raiseGateUp
          }
          guards {
            Guards.isEventDataFalse
          }
        }
      }
    }
    new {
      name = "left"
      initial = true
      on {
        // ^
        new {
          event  = Events.sensor
          target = "away"
          guards {
            Guards.isEventDataFalse
          }
        }
        // ^
        new {
          event  = Events.sensor
          actions {
            Actions.raiseLightOff
            Actions.raiseGateUp
          }
          guards {
            Guards.isEventDataTrue 
          }
        }
      }
    }
  }
  // Nested state machines, one for managing the gate and one for managing the light.
  stateMachines {
    Gate.stateMachine
    Light.stateMachine
  }
}