module actions

import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/CollaborativeStateMachineDescription.pkl" as CSML

import "events.pkl" as Events

raiseGateUp: CSML.RaiseActionDescription = new {
  event {
    name = Events.gateUp
    channel = "internal"
  }
}

raiseGateDown: CSML.RaiseActionDescription = new {
  event {
    name = Events.gateDown
    channel = "internal"
  }
}

raiseLightOn: CSML.RaiseActionDescription = new {
  event {
    name = Events.lightOn
    channel = "internal"
  }
}

raiseLightOff: CSML.RaiseActionDescription = new {
  event {
    name = Events.lightOff
    channel = "internal"
  }
}

doGateUp: CSML.InvokeActionDescription = new {
  serviceType = "gateUp"
}

doGateDown: CSML.InvokeActionDescription = new {
  serviceType = "gateDown"
}

doLightOn: CSML.InvokeActionDescription = new {
  serviceType = "lightOn"
}

doLightOff: CSML.InvokeActionDescription = new {
  serviceType = "lightOff"
}