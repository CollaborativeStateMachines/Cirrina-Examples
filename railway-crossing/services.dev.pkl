amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/ServiceImplementationBindings.pkl"

bindings {
  new HttpServiceImplementationBinding {
    name = "bellOn"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/bell/on"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "bellOff"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/bell/off"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "gateUp"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/gate/up"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "gateDown"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/gate/down"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "lightOn"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/light/on"
    method = "POST"
  }
  new HttpServiceImplementationBinding {
    name = "lightOff"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/light/off"
    method = "POST"
  }
}