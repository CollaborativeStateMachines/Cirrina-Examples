import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"

import "events.pkl"

// Action that invokes a service that puts the gate up.
const gateUpAction = new Csml.InvokeActionDescription {
  serviceType = "gateUp"
  done {
    new {
      name    = events.bellOff
      channel = "global"
    }
  }
}

// Action that raises the bell on event.
const raiseBellOnAction = new Csml.RaiseActionDescription {
  event {
    name    = events.bellOn
    data {
      new {
        name = "approachingSpeed"
        value = "$approachingSpeed"
      }
    }
    channel = "global"
  }
}

// Action that invokes a service that puts the gate down. Appends the current train speed as input and receives the delay after which the gate is lowered as output.
const gateDownAction = new Csml.InvokeActionDescription {
  serviceType = "gateDown"
  input {
    new {
      name = "approachingSpeed"
      value = "$approachingSpeed"
    }
  }
  output {
    new {
      reference = "downDelay"
    }
  }
  done {
    new {
      name = "gateIsDown"
      data {
        new {
          name = "downDelay"
          value = "downDelay"
        }
      }
      channel = "global"
    }
  }
}

// Gate state machine, manages a gate.
//
//
//                down      
//             ┌────────┐   
//             │        ▼   
//         ╔══════╗ ┌──────┐
//         ║  up  ║ │ down │
//         ╚══════╝ └───┬──┘
//            ▲         │   
//            └─────────┘   
//                up      
class GateStateMachine extends Csml.StateMachineDescription {
  name = "gate"
  localContext {
    variables {
      new {
        name = "downDelay"
        value = "0"
      }
    }
  }
  states {
    // The gate is initially up.
    new {
      name    = "up"
      initial = true
      entry { gateUpAction }
      on {
        new {
          event  = events.gateDown
          target = "down"
        }
      }
    }
    new {
      name = "down"
      entry { 
        raiseBellOnAction
        gateDownAction
      }
      on {
        new {
          event  = events.gateUp
          target = "up"
        }
      }
    }
  }
}