module light

import "CSML:CollaborativeStateMachineDescription"

import "@railway-crossing/crossing/light/actions.pkl"   as Actions

import "@railway-crossing/crossing/events.pkl" as Events

stateMachine = new CSML.StateMachineDescription {
  name = "light"
  states {
    new {
      name = "off"
      initial = true
      on {
        new {
          event   = Events.lightOff
          actions { Actions.lightOff }
        }
        new {
          event  = Events.lightOn
          target = "on"
        }
      }
    }
    new {
      name = "on"
      on {
        new {
          event  = Events.lightOff
          target = "off"
        }
        new {
          event   = Events.lightOn
          actions { Actions.lightOn }
        }
      }
    }
  }
}