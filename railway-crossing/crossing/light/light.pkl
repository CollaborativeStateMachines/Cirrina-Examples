import "@csm/Csml.pkl"

import "actions.pkl"

import ".../events.pkl"

class LightStateMachine extends Csml.StateMachine {
  name = "light"
  states {
    new {
      name    = "off"
      initial = true
      on {
        new {
          event   = events.lightOff
          actions { new actions.LightOffAction {} }
        }
        new {
          event  = events.lightOn
          target = "on"
        }
      }
    }
    new {
      name = "on"
      on {
        new {
          event  = events.lightOff
          target = "off"
        }
        new {
          event   = events.lightOn
          actions { new actions.LightOnAction {} }
        }
      }
    }
  }
}