import "@csm/Csml.pkl"

import "actions.pkl"

import ".../events.pkl"

/// Light state machine, manages a light.
///
///                off      
///            ┌───────┐   
///            │       ▼   
///         ╔═════╗ ┌─────┐
///         ║ on  ║ │ off │
///         ╚═════╝ └──┬──┘
///            ▲       │   
///            └───────┘   
///                on      
class LightStateMachine extends Csml.StateMachine {
  name = "light"
  states {
    // The light is initially off.
    new {
      name    = "off"
      initial = true
      on {
        new {
          event   = events.lightOff
          actions { new actions.LightOffAction {} }
        }
        new {
          event  = events.lightOn
          target = "on"
        }
      }
    }
    new {
      name = "on"
      on {
        new {
          event  = events.lightOff
          target = "off"
        }
        new {
          event   = events.lightOn
          actions { new actions.LightOnAction {} }
        }
      }
    }
  }
}