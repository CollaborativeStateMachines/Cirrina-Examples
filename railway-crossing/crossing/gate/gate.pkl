import "@csm/Csml.pkl"

import "actions.pkl"

import ".../events.pkl"

/// Gate state machine, manages a gate.
///
///
///                down      
///             ┌────────┐   
///             │        ▼   
///         ╔══════╗ ┌──────┐
///         ║  up  ║ │ down │
///         ╚══════╝ └───┬──┘
///            ▲         │   
///            └─────────┘   
///                up      
class GateStateMachine extends Csml.StateMachine {
  name = "gate"
  states {
    // The gate is initially up.
    new {
      name    = "up"
      initial = true
      entry {
        new actions.GateUpAction {}
      }
      on {
        new {
          event  = events.gateDown
          target = "down"
        }
      }
    }
    new {
      name = "down"
      entry {
        new actions.GateDownAction {}
      }
      on {
        new {
          event  = events.gateUp
          target = "up"
        }
      }
    }
  }
}