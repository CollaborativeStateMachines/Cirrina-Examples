module gate

import "CSML:CollaborativeStateMachineDescription"

import "@railway-crossing/crossing/gate/actions.pkl"   as Actions

import "@railway-crossing/crossing/events.pkl" as Events

stateMachine = new CSML.StateMachineDescription {
  name = "gate"
  states {
    new {
      name = "up"
      initial = true
      on {
        new {
          event   = Events.gateUp
          actions { Actions.gateUp }
        }
        new {
          event  = Events.gateDown
          target = "down"
        }
      }
    }
    new {
      name = "down"
      on {
        new {
          event = Events.gateUp
          target = "up"
        }
        new {
          event   = Events.gateDown
          actions { Actions.gateDown }
        }
      }
    }
  }
}