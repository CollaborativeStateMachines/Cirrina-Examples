import "@csm/Csml.pkl"

import "actions.pkl"

import ".../events.pkl"

class GateStateMachine extends Csml.StateMachine {
  name = "gate"
  states {
    new {
      name    = "up"
      initial = true
      on {
        new {
          event   = events.gateUp
          actions { new actions.GateUpAction {} }
        }
        new {
          event  = events.gateDown
          target = "down"
        }
      }
    }
    new {
      name = "down"
      on {
        new {
          event  = events.gateUp
          target = "up"
        }
        new {
          event   = events.gateDown
          actions { new actions.GateDownAction {} }
        }
      }
    }
  }
}