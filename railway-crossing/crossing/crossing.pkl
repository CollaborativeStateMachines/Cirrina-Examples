import "@csm/Csml.pkl"

import "actions.pkl"
import "guards.pkl"
import "vars.pkl"

import ".../events.pkl"

class CrossingStateMachine extends Csml.StateMachine {
  name = "crossing"
  localContext {
    variables {
      new vars.NumTrainsPassed {}
    }
  }
  states {
    new {
      name    = "init"
      initial = true
      entry {
        new actions.RaiseLightOnAction {}
        new actions.RaiseGateUpAction {}
      }
      always {
        new {
          target = "away"
        }
      }
    }
    new {
      name = "away"
      on {
        new {
          event  = events.sensor
          target = "approach"
          guards { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "approach"
      entry { new actions.RaiseLightOnAction {} }
      on {
        new {
          event  = events.sensor
          target = "close"
          guards { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
    new {
      name = "close"
      entry {
        new actions.RaiseGateDownAction {}
      }
      on {
        new {
          event  = events.sensor
          target = "present"
          guards { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "present"
      on {
        new {
          event  = events.sensor
          target = "leaving"
          guards { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
    new {
      name = "leaving"
      entry {
        new actions.RaiseLightOffAction {}
      }
      
      on {
        new {
          event  = events.sensor
          target = "left"
          guards { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "left"
      entry {
        new actions.RaiseGateUpAction {}
      }
      on {
        new {
          event  = events.sensor
          target = "away"
          guards { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
  }
}