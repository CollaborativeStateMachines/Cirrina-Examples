import "@csm/Csml.pkl"

import "actions.pkl"
import "events.pkl"
import "guards.pkl"

import "gate/gate.pkl"
import "light/light.pkl"

import "vars.pkl"

class CrossingStateMachine extends Csml.StateMachine {
  name = "crossing"
  localContext {
    variables {
      new vars.NumTrainsPassed {}
    }
  }
  states {
    new {
      name    = "away"
      initial = true
      entry {
        new actions.RaiseLightOffAction {}
        new actions.RaiseGateUpAction {}
      }
      on {
        new {
          event  = events.sensor
          target = "approach"
          guards { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "approach"
      entry {
        new actions.RaiseLightOnAction {}
        new actions.RaiseGateDownAction {}
      }
      on {
        new {
          event  = events.sensor
          target = "close"
          guards { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
    new {
      name = "close"
      on {
        new {
          event  = events.sensor
          target = "present"
          guards { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "present"
      on {
        new {
          event  = events.sensor
          target = "leaving"
          guards { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
    new {
      name = "leaving"
      on {
        new {
          event  = events.sensor
          target = "left"
          guards { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "left"
      on {
        new {
          event  = events.sensor
          target = "away"
          guards { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
  }
  stateMachines {
    new gate.GateStateMachine {}
    new light.LightStateMachine {}
  }
}