import "@csm/Csml.pkl"

import "actions.pkl"
import "events.pkl"
import "guards.pkl"

import "gate/gate.pkl"
import "light/light.pkl"

class CrossingStateMachine extends Csml.StateMachine {
  name = "crossing"
  localContext {
    variables {
      new { name  = "numTrainsPassedCrossing"; value = "0" }
    }
  }
  states {
    new {
      name    = "away"
      initial = true
      on {
        new {
          event  = events.sensor
          target = "approach"
          guards { new guards.IsEventDataTrueGuard {} }
        }
        new {
          event   = events.sensor
          actions { new actions.RaiseLightOffAction {} ; new actions.RaiseGateUpAction {} }
          guards  { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
    new {
      name = "approach"
      on {
        new {
          event  = events.sensor
          target = "close"
          guards { new guards.IsEventDataFalseGuard {} }
        }
        new {
          event   = events.sensor
          actions { new actions.RaiseLightOnAction {}; new actions.RaiseGateDownAction {} }
          guards  { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "close"
      on {
        new {
          event  = events.sensor
          target = "present"
          guards { new guards.IsEventDataTrueGuard {} }
        }
        new {
          event   = events.sensor
          actions { new actions.RaiseLightOnAction {}; new actions.RaiseGateDownAction {} }
          guards  { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
    new {
      name = "present"
      on {
        new {
          event  = events.sensor
          target = "leaving"
          guards { new guards.IsEventDataFalseGuard {} }
        }
        new {
          event   = events.sensor
          actions { new actions.RaiseLightOnAction {}; new actions.RaiseGateDownAction {} }
          guards  { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
    new {
      name = "leaving"
      initial = true
      on {
        new {
          event  = events.sensor
          target = "left"
          guards { new guards.IsEventDataTrueGuard {} }
        }
        new {
          event   = events.sensor
          actions { new actions.RaiseLightOffAction {}; new actions.RaiseGateUpAction {} }
          guards  { new guards.IsEventDataFalseGuard {} }
        }
      }
    }
    new {
      name = "left"
      initial = true
      on {
        new {
          event  = events.sensor
          target = "away"
          guards { new guards.IsEventDataFalseGuard {} }
        }
        new {
          event   = events.sensor
          actions { new actions.RaiseLightOffAction {}; new actions.RaiseGateUpAction {} }
          guards  { new guards.IsEventDataTrueGuard {} }
        }
      }
    }
  }
  stateMachines {
    new gate.GateStateMachine {}
    new light.LightStateMachine {}
  }
}