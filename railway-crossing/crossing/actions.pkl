module actions

import "CSML:CollaborativeStateMachineDescription"

import "@railway-crossing/crossing/events.pkl" as Events

raiseGateUp: CSML.RaiseActionDescription = new {
  event {
    name = Events.gateUp
    channel = "internal"
  }
}

raiseGateDown: CSML.RaiseActionDescription = new {
  event {
    name = Events.gateDown
    channel = "internal"
  }
}

raiseLightOn: CSML.RaiseActionDescription = new {
  event {
    name = Events.lightOn
    channel = "internal"
  }
}

raiseLightOff: CSML.RaiseActionDescription = new {
  event {
    name = Events.lightOff
    channel = "internal"
  }
}