import "@csm/Csml.pkl"

import "events.pkl"

/// Action that raises the gate up event.
class RaiseGateUpAction extends Csml.RaiseAction {
  event {
    name    = events.gateUp
    channel = "internal"
  }
}

/// Action that raises the gate down event.
class RaiseGateDownAction extends Csml.RaiseAction {
  event {
    name    = events.gateDown
    channel = "internal"
  }
}

/// Action that raises the light on event.
class RaiseLightOnAction extends Csml.RaiseAction {
  event {
    name    = events.lightOn
    channel = "internal"
  }
}

/// Action that raises the light off event.
class RaiseLightOffAction extends Csml.RaiseAction {
  event {
    name    = events.lightOff
    channel = "internal"
  }
}