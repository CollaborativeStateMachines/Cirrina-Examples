import "csm:Csml"

import "events.pkl"

// Action that invokes a service that turns the light on.
const lightOnAction = new Csml.InvokeActionDescription {
  serviceType = "lightOn"
}

// Action that invokes a service that turns the light off.
const lightOffAction = new Csml.InvokeActionDescription {
  serviceType = "lightOff"
}

// Light state machine, manages a light.
//
//                off      
//            ┌───────┐   
//            │       ▼   
//         ╔═════╗ ┌─────┐
//         ║ on  ║ │ off │
//         ╚═════╝ └──┬──┘
//            ▲       │   
//            └───────┘   
//                on      
class LightStateMachine extends Csml.StateMachineDescription {
  name = "light"
  states {
    // The light is initially off.
    new {
      name    = "off"
      initial = true
      entry { lightOffAction }
      on {
        new {
          event  = events.lightOn
          target = "on"
        }
      }
    }
    new {
      name = "on"
      entry { lightOnAction }
      on {
        new {
          event   = events.lightOn
          actions { lightOnAction }
        }
      }
    }
  }
}