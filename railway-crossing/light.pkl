import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"

import "events.pkl"

// Action that invokes a service that turns the light on.
const lightOnAction = new Csml.InvokeActionDescription {
  serviceType = "lightOn"
  input {
    new {
      name = "approachingSpeed"
      value = "$approachingSpeed"
    }
  }
}

// Action that invokes a service that turns the light off.
const lightOffAction = new Csml.InvokeActionDescription {
  serviceType = "lightOff"
}

// Action that invokes a service that turns the light to an early warning state.
const lightEarlyWarningAction = new Csml.InvokeActionDescription {
  serviceType = "lightEarlyWarning"
}

// Light state machine, manages a light.
//
//                off      
//            ┌───────┐   
//            │       ▼   
//         ╔═════╗ ┌─────┐
//         ║ on  ║ │ off │
//         ╚═════╝ └──┬──┘
//            ▲       │   
//            └───────┘   
//                on      
class LightStateMachine extends Csml.StateMachineDescription {
  name = "light"
  states {
    // The light is initially off.
    new {
      name = "off"
      initial = true
      entry { lightOffAction }
      on {
        new {
          event = events.lightOn
          target = "on"
        }
        new {
          event = events.lightEarlyWarning
          target = "earlyWarning" }
      }
    }
    new {
      name = "on"
      entry { lightOnAction }
      on {
        new {
          event = events.lightOff
          target = "off"
        }
      }
    }
    new {
      name = "earlyWarning"
      entry { lightEarlyWarningAction }
      on {
        new {
          event = events.lightOn
          target = "on"
        }
      }
    }
  }
}