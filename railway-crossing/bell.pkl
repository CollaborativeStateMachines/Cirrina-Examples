import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"

import "events.pkl"

// Action that invokes a service that turns the bell on.
const onAction = new Csml.InvokeActionDescription {
  serviceType = "bellOn"
  input {
    new {
      name = "approachingSpeed"
      value = "$approachingSpeed"
    }
  }
}

// Action that invokes a service that turns the bell off.
const offAction = new Csml.InvokeActionDescription {
  serviceType = "bellOff"
  input {
    new {
      name = "traceId"
      value = "$traceId"
    }
    new {
      name = "spanId"
      value = "$spanId"
    }
  }
}

// Bell state machine, manages a bell.
//
//                off      
//            ┌───────┐   
//            │       ▼   
//         ╔═════╗ ┌─────┐
//         ║ on  ║ │ off │
//         ╚═════╝ └──┬──┘
//            ▲       │   
//            └───────┘   
//                on      
class BellStateMachine extends Csml.StateMachineDescription {
  name = "bell"
  states {
    // The bell is initially off.
    new {
      name = "init"
      initial = true
      on {
        new {
          event = events.bellOff
          target = "off"
        }
      }
    }
    new {
      name    = "off"
      entry { offAction }
      on {
        new {
          event  = events.bellOn
          target = "on"
        }
      }
    }
    new {
      name = "on"
      entry { onAction }
      on {
        new {
          event  = events.bellOff
          target = "off"
        }
      }
    }
  }
}