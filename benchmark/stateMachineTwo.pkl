import "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/Csml.pkl"

class StateMachine extends Csml.StateMachineDescription {
  name = "stateMachineTwo"
  states {
    // Create new variable to increment
    new Csml.StateDescription {
      name = "setup"
      initial = true
      entry {
        new Csml.CreateActionDescription {
          variable = new Csml.ContextVariableDescription {
            name = "v1"
            value = "1"
          }
          isPersistent = true
        }
      }
      always {
        new Csml.TransitionDescription {
          target = "s1"
        }
      }
    }
    // Increment v1 and switch to s2
    new Csml.StateDescription {
      name = "s1"
      entry {
        new Csml.AssignActionDescription {
          variable = new {
            name = "v1"
            value = "v1 + 1"
          }
        }
      }
      after {
        new Csml.TimeoutActionDescription {
          name = "switch"
          delay = "1"
          action = new Csml.RaiseActionDescription {
            event {
              name = "leave"
              channel = "internal"
            }
          }
        }
      }
      on {
        new Csml.OnTransitionDescription {
          event = "leave"
          target = "s2"
        }
      }
    }
    // Increment v1 and switch to s1 or s3 depending on variable value
    new Csml.StateDescription {
      name = "s2"
      entry {
        new Csml.AssignActionDescription {
          variable = new {
            name = "v1"
            value = "v1 + 1"
          }
        }
      }
      after {
        new Csml.TimeoutActionDescription {
          name = "switch"
          delay = "1"
          action = new Csml.RaiseActionDescription {
            event {
              name = "leave"
              channel = "internal"
            }
          }
        }
      }
      on {
        new Csml.OnTransitionDescription {
          event = "leave"
          guards {
            new Csml.GuardDescription {
              expression = "v1 <= 100000"
            }
          }
          target = "s1"

        }
        new Csml.OnTransitionDescription {
          event = "leave"
          guards {
            new Csml.GuardDescription {
              expression = "v1 > 100000"
            }
          }
          target = "s3"

        }
      }
    }
    // End state machine
    new Csml.StateDescription {
      name = "s3"
      terminal = true
    }
  }
}