amends "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/ServiceImplementationBindings.pkl"
bindings {
  new HttpServiceImplementationBinding {
    name = "calculateFib"
    `local` = true
    scheme = "http"
    host = "localhost"
    port = 8000
    endPoint = "/calcFib"
    method = "POST"
  }
}