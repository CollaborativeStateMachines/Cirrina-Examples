amends
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

collaborativeStateMachine {
  stateMachines {
    ["chameneos"] {
      transient {
        ["color"] = "std:takeRandom([1,2,3,...])"
        ["count"] = "0"
      }
      states {
        ["wait"] = new Initial {
          on {
            ["start"] = new Transition { to = "request"}
          }
        }
        ["request"] = new State {
          entry {
            new Emit {
              event {
                topic = "requesting"
                data { ["id"] = "id"; ["color"] = "color" }
              }
            }
          }
          on {
            ["matchMade"] = new Transition {
              to = "request"
              yields {
                new Assign {
                  expression = "color = (function (x,y) { if (x == y) {x} else  {x ^ y} })(color, $color)"
                }
                new Assign { expression = "++count" }
                new Emit {
                  event {
                    topic = "change"
                    data { ["color"] = "color" }
                  }
                  target = "$partner"
                }
              }
            }
            ["change"] = new Transition {
              to = "request"
              yields {
                new Assign { expression = "color = $color" }
                new Assign { expression = "++count" }
              }
            }
            ["done"] = new Transition { to = "done" }
          }
        }
        ["done"] = new Terminal {}
      }
    }
    ["mall"] {
      transient {
        ["waiting"] = "[...]"
        ["count"] = "0"
        ["terminated"] = "0"
      }
      states {
        ["wait"] = new Initial {
          on {
            ["requesting"] = new Transition {
              yields {
                new Match {
                  cases {
                    new Case {
                      of = "waiting.isEmpty() && count < 20000"
                      yields {
                        new Assign { expression = "waiting += [$id]" }
                      }
                    }
                    new Case {
                      of = "!waiting.isEmpty() && count < 20000"
                      yields {
                        new Assign { expression = "++count" }
                        new Emit {
                          event {
                            topic = "matchMade"
                            data {
                              ["partner"] = "$id"
                              ["color"] = "$color"
                            }
                          }
                          target = "waiting.get(0)"
                        }
                        new Assign { expression = "waiting -= [waiting.get(0)]" }
                      }
                    }
                    new Case { of = "count == 20000"; yields {
                      new Emit { event { topic = "done" } }
                      new Assign { expression = "++count" }
                    }}
                  }

                }
              }
            }
            ["done"] = new Transition { to = "done" }
          }
        }
        ["done"] = new State {}
      }
    }
  }
}

instances {
  ["mall"] { stateMachineName = "mall" }
  ["chameneos0"] { stateMachineName = "chameneos"; data { ["id"] = "0"; } }
  ["chameneos1"] { stateMachineName = "chameneos"; data { ["id"] = "1"; } }
  ["chameneos2"] { stateMachineName = "chameneos"; data { ["id"] = "2"; } }
  ["chameneos3"] { stateMachineName = "chameneos"; data { ["id"] = "3"; } }
  ["chameneos4"] { stateMachineName = "chameneos"; data { ["id"] = "4"; } }
  ["chameneos5"] { stateMachineName = "chameneos"; data { ["id"] = "5"; } }
  ["chameneos6"] { stateMachineName = "chameneos"; data { ["id"] = "6"; } }
  ["chameneos7"] { stateMachineName = "chameneos"; data { ["id"] = "7"; } }
  ["chameneos8"] { stateMachineName = "chameneos"; data { ["id"] = "8"; } }
  ["chameneos9"] { stateMachineName = "chameneos"; data { ["id"] = "9"; } }
  ["chameneos10"] { stateMachineName = "chameneos"; data { ["id"] = "10"; } }
  ["chameneos11"] { stateMachineName = "chameneos"; data { ["id"] = "11"; } }
}
