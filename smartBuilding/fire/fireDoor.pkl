import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  states {
    ["openDoor"] = new csml.Initial {
      entry { new csml.Invoke { type = "openFireDoorService"; input { ["doorId"] = "doorId" } } }
      on { ["fireAlarm"] { to = "closeDoor" } }
    }
    ["closeDoor"] = new csml.State {
      entry { new csml.Invoke { type = "closeFireDoorService"; input { ["doorId"] = "doorId" } } }
      on { ["disarmFireAlarm"] { to = "openDoor" } }
    }
  }
}
