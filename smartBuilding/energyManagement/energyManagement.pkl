import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"

sm = new csml.StateMachine {
  transient = new Mapping {
    ["energyPrice"] = "'0'"
    ["gridStatus"] = "'normal'"
    ["currentSchedule"] = "'unknown'"
  }
  states {
    ["normal"] = new csml.Initial {
      entry {
        new csml.Emit { event { topic = "deactivateEnergySaving" } }
        new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
      }
      after {
        ["energyPoll"] = new csml.Timeout {
          delay = "300000"
          triggers = new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
        }
      }
      on {
        ["startEnergyCheck"] {
          yields {
            new csml.Invoke {
              type = "getEnergyPriceService"
              output { "energyPrice" }
              emits {
                new csml.ConditionalEvent { event = new csml.Internal { topic = "priceCheckDone" } }
              }
            }
          }
        }
        ["priceCheckDone"] {
          yields {
            new csml.Invoke {
              type = "checkGridStatusService"
              output { "gridStatus" }
              emits {
                new csml.ConditionalEvent {
                  provided = "gridStatus == 'demandResponse'"
                  event = new csml.Internal { topic = "goGridResponse" }
                }
                new csml.ConditionalEvent {
                  provided = "energyPrice > maxEnergyPrice"
                  event = new csml.Internal { topic = "goPeak" }
                }
              }
            }
          }
        }
        ["goGridResponse"] { to = "gridResponse" }
        ["goPeak"] { to = "peak" }
        ["enterBusinessHours"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'businessHours'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["enterAfterHours"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'afterHours'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["enterWeekend"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'weekend'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["fireAlarm"] { to = "safetyLockout" }
        ["gasLeakDetected"] { to = "gasShutdown" }
      }
    }
    ["peak"] = new csml.State {
      entry {
        new csml.Emit { event { topic = "energySaving" } }
      }
      after {
        ["energyPoll"] = new csml.Timeout {
          delay = "30000"
          triggers = new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
        }
      }
      on {
        ["startEnergyCheck"] {
          yields {
            new csml.Invoke {
              type = "getEnergyPriceService"
              output { "energyPrice" }
              emits {
                new csml.ConditionalEvent { event = new csml.Internal { topic = "priceCheckDone" } }
              }
            }
          }
        }
        ["priceCheckDone"] {
          yields {
            new csml.Invoke {
              type = "checkGridStatusService"
              output { "gridStatus" }
              emits {
                new csml.ConditionalEvent {
                  provided = "gridStatus == 'demandResponse'"
                  event = new csml.Internal { topic = "goGridResponse" }
                }
                new csml.ConditionalEvent {
                  provided = "energyPrice > maxEnergyPrice"
                  event = new csml.Internal { topic = "goPeak" }
                }
                new csml.ConditionalEvent {
                  provided = "!(energyPrice > maxEnergyPrice) && !(gridStatus == 'demandResponse')"
                  event = new csml.Internal { topic = "goNormal" }
                }
              }
            }
          }
        }
        ["goGridResponse"] { to = "gridResponse" }
        ["stayPeak"] { to = "peak" }
        ["goNormal"] { to = "normal" }
        ["enterBusinessHours"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'businessHours'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["enterAfterHours"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'afterHours'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["enterWeekend"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'weekend'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["fireAlarm"] { to = "safetyLockout" }
        ["gasLeakDetected"] { to = "gasShutdown" }
      }
    }
    ["gridResponse"] = new csml.State {
      entry {
        new csml.Emit { event { topic = "drasticEnergySaving" } }
      }
      after {
        ["energyPoll"] = new csml.Timeout {
          delay = "300000"
          triggers = new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
        }
      }
      on {
        ["startEnergyCheck"] {
          yields {
            new csml.Invoke {
              type = "getEnergyPriceService"
              output { "energyPrice" }
              emits {
                new csml.ConditionalEvent { event = new csml.Internal { topic = "priceCheckDone" } }
              }
            }
          }
        }
        ["priceCheckDone"] {
          yields {
            new csml.Invoke {
              type = "checkGridStatusService"
              output { "gridStatus" }
              emits {
                new csml.ConditionalEvent {
                  provided = "gridStatus == 'demandResponse'"
                  event = new csml.Internal { topic = "goGridResponse" }
                }
                new csml.ConditionalEvent {
                  provided = "energyPrice > maxEnergyPrice"
                  event = new csml.Internal { topic = "goPeak" }
                }
                new csml.ConditionalEvent {
                  provided = "!(energyPrice > maxEnergyPrice) && !(gridStatus == 'demandResponse')"
                  event = new csml.Internal { topic = "goNormal" }
                }
              }
            }
          }
        }
        ["stayGrid"] { to = "gridResponse" }
        ["goPeak"] { to = "peak" }
        ["goNormal"] { to = "normal" }
        ["enterBusinessHours"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'businessHours'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["enterAfterHours"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'afterHours'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["enterWeekend"] {
          yields {
            new csml.Eval { expression = "currentSchedule = 'weekend'" }
            new csml.Emit { event = new csml.Internal { topic = "startEnergyCheck" } }
          }
        }
        ["fireAlarm"] { to = "safetyLockout" }
        ["gasLeakDetected"] { to = "gasShutdown" }
      }
    }
    ["safetyLockout"] = new csml.State {
      entry {
        new csml.Emit { event { topic = "deactivateEnergySaving" } }
      }
      on {
        ["disarmFireAlarm"] { to = "normal" }
        ["gasLeakDetected"] { to = "gasShutdown" }
      }
    }
    ["gasShutdown"] = new csml.State {
      entry { new csml.Emit { event { topic = "energyShutdown" } } }
      on { ["gasPurged"] { to = "normal" } }
    }
  }
}
