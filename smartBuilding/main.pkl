amends
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina/refs/heads/develop/src/main/resources/pkl/csm/csml.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/buildingSchedule/buildingSchedule.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/buildingSchedule/roomSchedule.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/electricalSafety/electricalSafety.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/energyManagement/energyManagement.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/fire/fire.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/fire/fireDoor.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/gasSafety/gasSafety.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/hvac/hvac.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/lighting/lighting.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/roomOccupancy/roomOccupancy.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/security/accessControl.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/security/securityManager.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/shading/shading.pkl"
import
  "https://raw.githubusercontent.com/CollaborativeStateMachines/Cirrina-Examples/refs/heads/develop/smartBuilding/tempSafety/tempSafety.pkl"

collaborativeStateMachine {
  stateMachines {
    ["buildingSchedule"] = buildingSchedule.sm
    ["roomSchedule"] = roomSchedule.sm
    ["electricalSafety"] = electricalSafety.sm
    ["energyManagement"] = energyManagement.sm
    ["fire"] = fire.sm
    ["fireDoor"] = fireDoor.sm
    ["gasSafety"] = gasSafety.sm
    ["hvac"] = hvac.sm
    ["lighting"] = lighting.sm
    ["roomOccupancy"] = roomOccupancy.sm
    ["securityManager"] = securityManager.sm
    ["accessControl"] = accessControl.sm
    ["shading"] = shading.sm
    ["tempSafety"] = tempSafety.sm
  }
  persistent {
    ["isEnergySaving"] = "false"
    ["currentOccupancy"] = "'vacant'"
    ["isFireAlarm"] = "false"
    ["isGasActive"] = "false"
    ["isSmokeAlert"] = "false"
    ["arcFault"] = "false"
    ["desiredTemp"] = "21.0"
    ["tempThreshold"] = "60"
    ["maxEnergyPrice"] = "45.0"
  }
}

instances {
  ["buildingSchedule"] { stateMachineName = "buildingSchedule" }
  ["roomSchedule"] { stateMachineName = "roomSchedule"; data { ["roomId"] = "'Room 0'" } }
  ["electricalSafety"] { stateMachineName = "electricalSafety" }
  ["energyManagement"] { stateMachineName = "energyManagement" }
  ["fire"] { stateMachineName = "fire" }
  for (i in IntSeq(0, 100)) {
    ["\(i)"] {
      stateMachineName = "fireDoor"
      data { ["doorId"] = "'Door \(i)'" }
    }
  }
  ["gasSafety"] { stateMachineName = "gasSafety" }
  ["hvac"] { stateMachineName = "hvac"; data { ["roomId"] = "'Room 0'" } }
  ["lighting"] { stateMachineName = "lighting"; data { ["roomId"] = "'Room 0'" } }
  ["roomOccupancy"] { stateMachineName = "roomOccupancy"; data { ["roomId"] = "'Room 0'" } }
  ["securityManager"] { stateMachineName = "securityManager" }
  ["accessControl"] { stateMachineName = "accessControl"; data { ["doorId"] = "'Door 0'" } }
  ["shading"] { stateMachineName = "shading"; data { ["roomId"] = "'Room 0'" } }
  ["tempSafety"] { stateMachineName = "tempSafety"; data { ["roomId"] = "'Room 0'" } }
}

bindings {
  new HttpServiceImplementationBinding {
    name = "checkArcFaultService"
    `local` = false
    scheme = "http"
    host = "localhost"
    port = 8005
    endPoint = "/checkArcFault"
    method = "POST"
  }
